!(bind! &persistent (new-space))
!(bind! &agenda (new-space))
!(bind! &cycle (new-state 1))
!(bind! &practiceStartCycle (new-state 1))
!(bind! &practiceLabel (new-state "probe"))
!(bind! &loops (new-state 0))
!(bind! &energyMode (new-state "focused"))
!(bind! &maxNewInputLoops (new-state 25))
!(bind! &maxWakeLoops (new-state 20))
!(bind! &sleepInterval (new-state 3))
!(bind! &wakeupInterval (new-state 60))
!(bind! &nextWakeAt (new-state 0))
!(import! &self ../src/helper.py)
(= (trace-atom $action $space $atom $source) ())
!(import! &self ../src/skills_memory.metta)
!(import! &self ../src/skills_energy.metta)
!(persistent-rule "input | implies | wait | high")
!(agenda-goal "portable-test active bananas next step")
!(agenda-goal "bad-status nonsense high next step")
!(set-energy-mode banana "bad model guess")
!(persistent-atoms)
!(get-atoms &agenda)
!(attention-status)
