; Isolated smoke for the symbolic skill affordance registry.

!(import! &self (library lib_import))
!(import! &self (library lib_spaces))
!(bind! &persistent (new-space))
!(bind! &agenda (new-space))
!(bind! &beliefs (new-space))
!(bind! &world (new-space))
!(bind! &events (new-space))
!(bind! &activity (new-space))
!(import! &self ../src/skill_catalog.metta)
!(import! &self ../src/skill_catalog_core.metta)
!(import! &self ../src/skill_catalog_memory.metta)
!(import! &self ../src/skill_catalog_reasoning.metta)
!(import! &self ../src/skill_catalog_affordance.metta)
!(import! &self ../src/skills_runtime_spaces.metta)
!(import! &self ../src/skills_affordance.metta)
!(import! &self ../src/skill_affordance_core.metta)
!(import! &self ../src/skill_affordance_memory.metta)
!(import! &self ../src/skill_affordance_reasoning.metta)
!(import! &self ../src/skill_affordance_affordance.metta)


!(if (== (eval (getSkills)) (eval (getFullSkills)))
     (println! FAILED-SKILL-CONTEXT-HINTS-NOT-SLIM)
     (println! SKILL-CONTEXT-HINTS-SLIM-OK))

!(if (== (eval (space-known "skills")) true)
     (println! SKILL-AFFORDANCE-SPACE-OK)
     (println! FAILED-SKILL-AFFORDANCE-SPACE))
!(if (== (eval (query-skill-space "memory")) ())
     (println! FAILED-SKILL-AFFORDANCE-MEMORY-EMPTY)
     (println! SKILL-AFFORDANCE-MEMORY-OK))
!(if (== (eval (query-skill-space memory)) ())
     (println! FAILED-SKILL-AFFORDANCE-MEMORY-SYMBOL-EMPTY)
     (println! SKILL-AFFORDANCE-MEMORY-SYMBOL-OK))
!(if (== (eval (query-skill-space "reasoning")) ())
     (println! FAILED-SKILL-AFFORDANCE-REASONING-EMPTY)
     (println! SKILL-AFFORDANCE-REASONING-OK))
!(if (== (eval (choose-skill-for "test-symbolic-syntax")) ())
     (println! FAILED-SKILL-AFFORDANCE-CHOOSE-EMPTY)
     (println! SKILL-AFFORDANCE-CHOOSE-OK))
!(if (== (eval (explain-skill "space-find")) ())
     (println! FAILED-SKILL-AFFORDANCE-EXPLAIN-EMPTY)
     (println! SKILL-AFFORDANCE-EXPLAIN-OK))
!(if (== (eval (skill-card "remember")) ())
     (println! FAILED-SKILL-AFFORDANCE-CARD-EMPTY)
     (println! SKILL-AFFORDANCE-CARD-OK))
!(println! (eval (query-skill-space "affordance")))
!(println! (eval (choose-skill-for "find-tool-for-task")))

!(if (== (eval (skill-suggestions-for "has-question")) ())
     (println! FAILED-SKILL-TRIGGER-DEFAULT-EMPTY)
     (println! SKILL-TRIGGER-DEFAULT-OK))
!(println! (eval (suggest-skill-trigger "query" "mentions-word:lookup" 0.61 "observed missed memory lookup wording")))
!(if (== (eval (skill-trigger-candidates)) ())
     (println! FAILED-SKILL-TRIGGER-CANDIDATE-EMPTY)
     (println! SKILL-TRIGGER-CANDIDATE-OK))
!(println! (eval (promote-skill-trigger "query" "mentions-word:lookup" 0.66 "candidate reviewed and useful")))
!(if (== (eval (skill-suggestions-for "mentions-word:lookup")) ())
     (println! FAILED-SKILL-TRIGGER-PROMOTED-EMPTY)
     (println! SKILL-TRIGGER-PROMOTED-OK))
