; smoke-mode: runtime-skill
; smoke-purpose: imported OmegaClaw skill behavior; covered by Python unit tests and full-runtime live checks.
; smoke-note: direct MeTTa file execution does not reliably reduce imported skill definitions.
!(import! &self (library lib_import))
!(import! &self (library lib_spaces))
!(git-import! "https://github.com/asi-alliance/OmegaClaw-Core.git")
!(bind! &persistent (new-space))
!(bind! &agenda (new-space))
!(bind! &beliefs (new-space))
!(bind! &world (new-space))
!(bind! &events (new-space))
!(bind! &activity (new-space))
!(import! &self (library OmegaClaw-Core ./src/skills_memory.metta))
!(import! &self (library OmegaClaw-Core ./src/skills_runtime_spaces.metta))
!(register-default-runtime-spaces)

!(if (== (eval (space-known "persistent")) true)
     (println! REGISTRY-PERSISTENT-STRING-OK)
     (println! FAILED-REGISTRY-PERSISTENT-STRING))
!(if (== (eval (space-known persistent)) true)
     (println! REGISTRY-PERSISTENT-SYMBOL-OK)
     (println! FAILED-REGISTRY-PERSISTENT-SYMBOL))
!(if (== (eval (space-known "dream")) false)
     (println! REGISTRY-UNKNOWN-OK)
     (println! FAILED-REGISTRY-UNKNOWN))
!(add-atom &persistent (RegistrySmoke "core" "ok"))
!(if (== (eval (space-count "persistent" "(RegistrySmoke $kind $status)")) 1)
     (println! REGISTRY-CORE-COUNT-OK)
     (println! FAILED-REGISTRY-CORE-COUNT))

!(bind! &dream (new-space))
!(if (== (eval (register-space "dream" &dream imagination)) (SpaceRegistered "dream" imagination))
     (println! REGISTRY-REGISTER-OK)
     (println! FAILED-REGISTRY-REGISTER))
!(if (== (eval (register-space-alias dream "dream")) (SpaceAliasRegistered dream "dream"))
     (println! REGISTRY-ALIAS-OK)
     (println! FAILED-REGISTRY-ALIAS))
!(if (== (eval (space-known "dream")) true)
     (println! REGISTRY-DREAM-STRING-OK)
     (println! FAILED-REGISTRY-DREAM-STRING))
!(if (== (space-known dream) true)
     (println! REGISTRY-DREAM-SYMBOL-OK)
     (println! FAILED-REGISTRY-DREAM-SYMBOL))
!(add-atom &dream (DreamAtom "new-space" "ok"))
!(if (== (eval (space-count "dream" "(DreamAtom $name $status)")) 1)
     (println! REGISTRY-DREAM-COUNT-OK)
     (println! FAILED-REGISTRY-DREAM-COUNT))
!(if (== (eval (space-find dream "(DreamAtom $name $status)")) ())
     (println! FAILED-REGISTRY-DREAM-FIND)
     (println! REGISTRY-DREAM-FIND-OK))
!(println! (eval (space-pressure)))
!(if (== (eval (space-persistence-entry "persistent")) ())
     (println! FAILED-REGISTRY-PERSISTENCE-ENTRY)
     (println! REGISTRY-PERSISTENCE-ENTRY-OK))
!(println! (eval (load-runtime-space "persistent")))

!(bind! &scratch (new-space))
!(println! (eval (register-space "scratch" &scratch scratch)))
!(println! (eval (register-space-persistence "scratch" /tmp/omega-space-registry-smoke.metta runtime-state)))
!(add-atom &scratch (ScratchPersistence "save" "ok"))
!(println! (eval (save-runtime-space "scratch")))
!(bind! &scratch (new-space))
!(println! (eval (load-runtime-space "scratch")))
!(if (== (eval (space-count "scratch" "(ScratchPersistence $kind $status)")) 1)
     (println! REGISTRY-PERSISTENCE-ROUNDTRIP-OK)
     (println! FAILED-REGISTRY-PERSISTENCE-ROUNDTRIP))
!(println! (eval (load-runtime-space "scratch")))
!(if (== (eval (space-count "scratch" "(ScratchPersistence $kind $status)")) 1)
     (println! REGISTRY-PERSISTENCE-IDEMPOTENT-LOAD-OK)
     (println! FAILED-REGISTRY-PERSISTENCE-IDEMPOTENT-LOAD))

; Re-running the explicit init step should not create duplicate active registry entries.
!(register-default-runtime-spaces)
!(if (== (match-count &self (SpaceRegistry "persistent" $handle $role)) 1)
     (println! REGISTRY-REIMPORT-IDEMPOTENT-OK)
     (println! FAILED-REGISTRY-REIMPORT-DUPLICATE))
!(if (== (match-count &self (SpacePersistence "persistent" $path $mode)) 1)
     (println! REGISTRY-PERSISTENCE-REIMPORT-OK)
     (println! FAILED-REGISTRY-PERSISTENCE-REIMPORT))
!(if (== (match-count &self (SpaceRegistry "dream" $handle $role)) 1)
     (println! REGISTRY-DREAM-REIMPORT-OK)
     (println! FAILED-REGISTRY-DREAM-REIMPORT))
