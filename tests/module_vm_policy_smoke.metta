!(import! &self (library lib_import))
!(git-import! "https://github.com/asi-alliance/OmegaClaw-Core.git")
!(import! &self (library OmegaClaw-Core modules/vm_policy/entry.metta))

!(println! (match &self (TrustedRuntimeOrgan "vm-policy") true))
!(println! (eval (initVMPolicyOrgan)))
!(println! (eval (vm-policy-status)))
!(println! (eval (vm-policy-exits)))
!(println! (eval (vm-policy-atoms)))
!(println! (eval (vm-policy-connections)))
!(println! (eval (vm-policy-metrics)))
!(println! (eval (vm-policy-maintenance-window github "patch review duration=5m")))
!(println! (eval (vm-policy-record-exit github "temporary patch review")))
!(println! (eval (vm-policy-exit-history)))
!(println! (eval (vm-policy-exit-summary)))
!(println! (match &self (BoundaryOrgan $organ) $organ))
!(println! (match &self (BoundaryPrinciple vm-policy $principle) $principle))
