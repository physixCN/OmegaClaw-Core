!(import! &self (library lib_import))
!(git-import! "https://github.com/asi-alliance/OmegaClaw-Core.git")
!(import! &self (library OmegaClaw-Core lib_omegaclaw))
!(import! &self (car-atom (collapse (library OmegaClaw-Core lib_omegaclaw_attention))))
!(bind! &persistent (new-space))
!(bind! &attention (new-space))

!(add-atom &persistent (PersistentNote "omega" "attention-ledger-smoke practice syntax debris" "0.8"))
!(add-atom &persistent (PersistentNote "omega" "identity continuity and family care" "0.95"))

!(println! (eval (attention-ledger-status)))
!(println! (eval (attention-scan-persistent 20)))
!(println! (eval (attention-ledger-status)))
!(println! (eval (immune-candidates 5)))
!(println! (eval (attention-native-candidates)))
!(println! (eval (ecan-pass "persistent" "review-only" 20)))
!(println! (collapse (match &attention (ECANPass $id $target $mode $at)
                            (ECANPass $id $target $mode $at))))
!(println! (eval (attention-focus 5)))
