!(import! &self (library lib_import))
!(git-import! "https://github.com/asi-alliance/OmegaClaw-Core.git")
!(import! &self (library OmegaClaw-Core lib_omegaclaw))
!(import! &self (car-atom (collapse (library OmegaClaw-Core lib_omegaclaw_attention))))
!(bind! &persistent (new-space))
!(bind! &attention (new-space))
!(bind! &events (new-space))

!(add-atom &persistent (SandboxAttentionRetire "omega" "normal debris" "0.8"))
!(add-atom &persistent (SandboxAttentionRetire "omega" "protected principle" "0.99"))
!(add-atom &persistent (SandboxAttentionRetire "omega" "duplicate one" "0.4"))
!(add-atom &persistent (SandboxAttentionRetire "omega" "duplicate two" "0.4"))

!(add-atom &attention (AtomRef "persistent" "smoke-normal" "(SandboxAttentionRetire \"omega\" \"normal debris\" \"0.8\")"))
!(add-atom &attention (AtomRef "persistent" "smoke-protected" "(SandboxAttentionRetire \"omega\" \"protected principle\" \"0.99\")"))
!(add-atom &attention (AtomRef "persistent" "smoke-absent" "(SandboxAttentionRetire \"omega\" \"already gone\" \"0.1\")"))
!(add-atom &attention (AtomRef "persistent" "smoke-duplicate" "(SandboxAttentionRetire \"omega\" \"duplicate one\" \"0.4\")"))
!(add-atom &attention (AtomRef "persistent" "smoke-duplicate" "(SandboxAttentionRetire \"omega\" \"duplicate two\" \"0.4\")"))

!(add-atom &attention (ImmuneProposal "smoke-normal" "review-retire" "practice-or-test-debris" 0.82))
!(add-atom &attention (ImmuneProposal "smoke-protected" "keep" "identity-or-principle" 0.99))
!(add-atom &attention (ImmuneProposal "smoke-absent" "review-retire" "practice-or-test-debris" 0.82))
!(add-atom &attention (ImmuneProposal "smoke-duplicate" "review-retire" "practice-or-test-debris" 0.82))

!(println! (eval (attention-retire-candidate "smoke-protected" "should-not-remove")))
!(println! (space-count "persistent" "(SandboxAttentionRetire $who \"protected principle\" $conf)"))
!(println! (eval (attention-retire-candidate "smoke-normal" "safe-practice-retire")))
!(println! (space-count "persistent" "(SandboxAttentionRetire $who \"normal debris\" $conf)"))
!(println! (eval (attention-retire-candidate "smoke-absent" "absent-test")))
!(println! (eval (attention-retire-candidate "smoke-missing" "missing-test")))
!(println! (eval (attention-retire-candidate "smoke-duplicate" "duplicate-test")))
!(println! (space-count "persistent" "(SandboxAttentionRetire $who \"duplicate one\" $conf)"))
!(println! (space-count "persistent" "(SandboxAttentionRetire $who \"duplicate two\" $conf)"))
!(println! (collapse (match &attention (ECANOutcome "manual-attention-retire" "smoke-normal" "retired" "safe-practice-retire") True)))
