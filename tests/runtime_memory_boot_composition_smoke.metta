!(import! &self (library lib_import))
!(git-import! "https://github.com/asi-alliance/OmegaClaw-Core.git")
!(import! &self (library OmegaClaw-Core lib_omegaclaw))

!(initLoop)
!(println! (initMemory))
!(if (== (eval (space-known "persistent")) true)
     (println! BOOT-COMPOSITION-PERSISTENT-OK)
     (println! FAILED-BOOT-COMPOSITION-PERSISTENT))
!(if (== (eval (space-known "activity")) true)
     (println! BOOT-COMPOSITION-ACTIVITY-OK)
     (println! FAILED-BOOT-COMPOSITION-ACTIVITY))
!(add-atom &world (BootComposition "world" "ok"))
!(if (== (eval (space-count "world" "(BootComposition $space $status)")) 1)
     (println! BOOT-COMPOSITION-WORLD-COUNT-OK)
     (println! FAILED-BOOT-COMPOSITION-WORLD-COUNT))
!(println! (space-pressure))
!(println! (pin "BOOT | composition smoke | no echo"))
!(println! (shell "printf shell-ok"))
!(println! (shell-confirm "printf confirm-ok"))
!(println! (metta "(+ 2 3)"))
!(println! (load-runtime-space "activity"))
!(println! (save-runtime-space "activity"))
