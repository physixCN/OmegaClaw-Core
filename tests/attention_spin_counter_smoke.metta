!(import! &self (library lib_import))
!(git-import! "https://github.com/asi-alliance/OmegaClaw-Core.git")
!(import! &self (library OmegaClaw-Core ./src/attention_spin.metta))
!(bind! &attention (new-space))
!(change-state! &spinCounter 0)

!(println! (eval (attention-spin-init)))
!(println! (eval (attention-observe-response false ((wait "one")))))
!(println! (eval (attention-observe-response false ((wait "two")))))
!(println! (eval (attention-observe-response false ((pin "p") (wait "x")))))
!(println! (eval (attention-observe-response false ((agenda-active)))))
!(println! (eval (attention-observe-response false ((wait "three")))))
!(println! (eval (attention-observe-response true ((wait "fresh input should reset")))))
!(println! (spin-counter-context))
