; Agentverse remote-agent affordance cards.

(SkillTopic "agentverse-status" "agentverse")
(SkillTopic "agentverse-listener-status" "agentverse")
(SkillTopic "agentverse-listener-start" "agentverse")
(SkillTopic "agentverse-listener-stop" "agentverse")
(SkillTopic "agentverse-discover" "agentverse")
(SkillTopic "agentverse-remote-agents" "agentverse")
(SkillTopic "agentverse-register-agent" "agentverse")
(SkillTopic "agentverse-call" "agentverse")
(SkillTopic "agentverse-ask" "agentverse")
(SkillTopic "agentverse-trace" "agentverse")
(SkillTopic "agentverse-inbox" "agentverse")

(SkillCardLine "agentverse-status" "agentverse-status - inspect Agentverse/uAgents readiness without exposing secrets")
(SkillCardLine "agentverse-listener-status" "agentverse-listener-status - inspect the local uAgent listener that receives async AgentChatProtocol replies")
(SkillCardLine "agentverse-listener-start" "agentverse-listener-start - start the local uAgent listener; needs OMEGACLAW_AGENTVERSE_ENDPOINT or a configured Agentverse mailbox")
(SkillCardLine "agentverse-listener-stop" "agentverse-listener-stop - stop the local uAgent listener process")
(SkillCardLine "agentverse-discover" "agentverse-discover query optional-limit - search for relevant remote agents; use quoted query plus numeric limit, e.g. agentverse-discover \"weather\" 5")
(SkillCardLine "agentverse-remote-agents" "agentverse-remote-agents - list locally registered RemoteAgent atoms")
(SkillCardLine "agentverse-register-agent" "agentverse-register-agent name address schema capability - register a chosen candidate once, then verify with agentverse-remote-agents; exact repeats return already-registered")
(SkillCardLine "agentverse-call" "agentverse-call name payload - call a known RemoteAgent atom; AgentChatProtocol sends an official ChatMessage and returns AGENTVERSE-ACK on delivery")
(SkillCardLine "agentverse-ask" "agentverse-ask destination schema payload - send a typed request to a remote agent; use schema AgentChatProtocol for agents advertising AgentChatProtocol")
(SkillCardLine "agentverse-ask" "AgentChatProtocol acknowledgement proves remote delivery, not necessarily the final async chat answer; full replies may require a listening local uAgent endpoint")
(SkillCardLine "agentverse-trace" "agentverse-trace - inspect recent Agentverse status, discovery, request, response, and error trace records")
(SkillCardLine "agentverse-inbox" "agentverse-inbox - inspect local listener outbound sends, acknowledgements, and inbound AgentChatProtocol replies")

(SkillTrigger "agentverse-discover" "mentions-word:agentverse" 0.75 "Agentverse wording may need remote-agent discovery")
(SkillTrigger "agentverse-discover" "mentions-word:agent" 0.48 "agent wording may need remote-agent discovery")

(Risk "agentverse-call" "external-network-call")
(Risk "agentverse-ask" "external-network-call")
(Risk "agentverse-listener-start" "starts-local-process")
(Effect "agentverse-discover" "remote-agent-candidates")
(Effect "agentverse-register-agent" "remote-agent-registry-update")
(Effect "agentverse-call" "remote-agent-response")
(Effect "agentverse-inbox" "remote-agent-response")

; Skill-card hygiene: every callable signature has a visible card and argument shape.
(Skill "agentverse-ask")
(Skill "agentverse-call")
(Skill "agentverse-discover")
(Skill "agentverse-inbox")
(Skill "agentverse-listener-start")
(Skill "agentverse-listener-status")
(Skill "agentverse-listener-stop")
(Skill "agentverse-register-agent")
(Skill "agentverse-remote-agents")
(Skill "agentverse-status")
(Skill "agentverse-trace")
(SkillArg "agentverse-status" 0 "none" "none")
(SkillArg "agentverse-listener-status" 0 "none" "none")
(SkillArg "agentverse-listener-start" 0 "none" "none")
(SkillArg "agentverse-listener-stop" 0 "none" "none")
(SkillArg "agentverse-discover" 1 "text" "query")
(SkillArg "agentverse-discover" 2 "optional-number" "limit")
(SkillArg "agentverse-remote-agents" 0 "none" "none")
(SkillArg "agentverse-register-agent" 1 "text" "name")
(SkillArg "agentverse-register-agent" 2 "text" "address")
(SkillArg "agentverse-register-agent" 3 "text" "schema")
(SkillArg "agentverse-register-agent" 4 "rest-text" "capability")
(SkillArg "agentverse-call" 1 "text" "name")
(SkillArg "agentverse-call" 2 "rest-text" "payload")
(SkillArg "agentverse-ask" 1 "text" "destination")
(SkillArg "agentverse-ask" 2 "text" "schema")
(SkillArg "agentverse-ask" 3 "rest-text" "payload")
(SkillArg "agentverse-trace" 0 "none" "none")
(SkillArg "agentverse-inbox" 0 "none" "none")
