; Catalog entries for the agent's tiny VM workspace-device.

(SkillCatalog "POC agent VM: vm-status, vm-boot, vm-shell command, vm-last-trace")
(SkillHelp "vm" "vm-status, vm-boot, vm-shell command, vm-last-trace")
(SkillHelp "vm" "the agent VM is a POC ephemeral tiny Linux workspace-device. It is a tool/body surface, not the agent's mind.")
