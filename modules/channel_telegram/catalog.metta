(SkillCatalog "Telegram channel: send-telegram message, send-telegram-base64 payload")
(SkillHelp "channels" "send-telegram message - send to configured Telegram control chat; message body only, no TELEGRAM:/chat_id/target prefix")
(SkillHelp "telegram" "send-telegram message; send-telegram-base64 payload - configured chat only; routing comes from Telegram config/auth state, not the message body")
