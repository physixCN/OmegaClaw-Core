; Codex Code organ: a repo-editing hand, not the agent self.

(Module omegaclaw.skill.codex-code)
(ModuleKind omegaclaw.skill.codex-code coding-organ)
(ModuleVersion omegaclaw.skill.codex-code "0.1.0")
(ModuleEntrypoint omegaclaw.skill.codex-code "entry.metta")
(ModuleOptional omegaclaw.skill.codex-code True)
(ModuleDefaultEnabled omegaclaw.skill.codex-code False)
(ModuleImplementation omegaclaw.skill.codex-code codex-cli-openrouter-membrane)

(Provider codex-code)
(CodingOrgan codex-code)
(Provides omegaclaw.skill.codex-code (Provider codex-code))
(Provides omegaclaw.skill.codex-code (Skill codex-code-status))
(Provides omegaclaw.skill.codex-code (Skill codex-code-atoms))
(Provides omegaclaw.skill.codex-code (Skill codex-code-containment-check))
(Provides omegaclaw.skill.codex-code (Skill codex-code))
(Provides omegaclaw.skill.codex-code (Skill codex-code-readonly))
(Provides omegaclaw.skill.codex-code (Skill codex-code-start))
(Provides omegaclaw.skill.codex-code (Skill codex-code-readonly-start))
(Provides omegaclaw.skill.codex-code (Skill codex-code-jobs))
(Provides omegaclaw.skill.codex-code (Skill codex-code-job-status))
(Provides omegaclaw.skill.codex-code (Skill codex-code-result))
(Provides omegaclaw.skill.codex-code (Skill codex-code-cancel))
(Provides omegaclaw.skill.codex-code (Skill codex-code-events))
(Provides omegaclaw.skill.codex-code (Skill codex-code-last-trace))
(Provides omegaclaw.coding.codex code-cognition)
(Provides omegaclaw.coding.codex code-review)
(Provides omegaclaw.coding.codex code-edit)

(UsesHarness codex-code CodexCLI)
(UsesProvider codex-code OpenRouter)
(UsesModel codex-code "qwen/qwen3-coder-next")
(CodexCodeContainment codex-code runtime-configured)
(CodexCodeSandboxBypass codex-code runtime-configured)
(OrganPrinciple codex-code "the agent reasons and chooses; Codex CLI and Qwen edit as a specialist coding hand; results are traced for review.")
(OrganPrinciple codex-code "Core defaults are conservative; deployments may choose VM-boundary containment when the VM is the real membrane.")

(RuntimeDependency omegaclaw.skill.codex-code python ">=3.10")
(RuntimeDependency omegaclaw.skill.codex-code node ">=20")
(RuntimeDependency omegaclaw.skill.codex-code npm "@openai/codex@0.133.0")
(RuntimeDependency omegaclaw.skill.codex-code openrouter "model:qwen/qwen3-coder-next")
(RuntimeConfig omegaclaw.skill.codex-code OMEGACLAW_CODEX_SANDBOX_READONLY "read-only")
(RuntimeConfig omegaclaw.skill.codex-code OMEGACLAW_CODEX_SANDBOX_EDIT "workspace-write")
(RuntimeConfig omegaclaw.skill.codex-code OMEGACLAW_CODEX_DANGEROUS_BYPASS "0")
(RuntimeConfig omegaclaw.skill.codex-code OMEGACLAW_CODEX_MAX_ACTIVE_JOBS "1")

(TraceWrites omegaclaw.skill.codex-code CodexCodeCall)
(TraceWrites omegaclaw.skill.codex-code CodexCodeResult)
(TraceWrites omegaclaw.skill.codex-code CodexJobStarted)
(TraceWrites omegaclaw.skill.codex-code CodexJobComplete)
(TraceWrites omegaclaw.skill.codex-code CodexJobError)

!(import! &self (car-atom (collapse (library OmegaClaw-Core ./src/codex_code.py))))
!(import! &self (car-atom (collapse (library OmegaClaw-Core ./modules/codex_code/catalog.metta))))
!(import! &self (car-atom (collapse (library OmegaClaw-Core ./modules/codex_code/affordance.metta))))
!(import! &self (car-atom (collapse (library OmegaClaw-Core ./modules/codex_code/signatures.metta))))
!(import! &self (car-atom (collapse (library OmegaClaw-Core ./modules/codex_code/skills.metta))))
