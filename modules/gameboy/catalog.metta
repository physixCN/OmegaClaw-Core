; Catalog entries for the Game Boy simulation organ.

(SkillCatalog "Game Boy simulation: gb-status, gb-load game, gb-observe, gb-step buttons frames, gb-screenshot, gb-save-state name, gb-load-state name, gb-stop, gb-last-trace")
(SkillHelp "gameboy" "gb-status, gb-load game, gb-observe, gb-step buttons frames, gb-screenshot, gb-save-state name, gb-load-state name, gb-stop, gb-last-trace")
(SkillHelp "gameboy" "ROMs are private runtime artifacts. Put your own dump at memory/runtime/gameboy/roms/pokemon-yellow.gb or use gb-load demo for the bundled PyBoy demo ROM.")
