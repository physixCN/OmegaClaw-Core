; Command syntax for the Game Boy simulation organ.

(SkillSignature gb-status)
(SkillSignature gb-load (Arg text game))
(SkillSignature gb-observe)
(SkillSignature gb-step (Arg rest-text action))
(SkillSignature gb-screenshot)
(SkillSignature gb-save-state (Arg text name))
(SkillSignature gb-stop)
(SkillSignature gb-load-state (Arg text name))
(SkillSignature gb-last-trace)
