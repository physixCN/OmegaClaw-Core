+
+def _claim_active_session_users():
+    users = _load_users()
+    changed = False
+    for username in _active_session_usernames():
+        user = users.get(username)
+        if user and not user.get("claimed"):
+            user["claimed"] = True
+            user["claimed_at"] = user.get("claimed_at") or time.strftime("%Y-%m-%d %H:%M:%S")
+            users[username] = user
+            changed = True
+    if changed:
+        _save_users(users)
