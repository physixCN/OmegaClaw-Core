+def _gallery_kind(path):
+    suffix = pathlib.Path(path).suffix.lower()
+    if suffix in {".mp4", ".webm"}:
+        return "Video"
+    if suffix in {".mp3", ".m4a", ".wav", ".ogg", ".opus", ".flac", ".aac"}:
+        return "Audio"
+    return "Image"
