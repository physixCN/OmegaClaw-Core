+def _active_session_usernames(sessions=None):
+    sessions = sessions if sessions is not None else _load_sessions()
+    now = int(time.time())
+    return {
+        str(item.get("username", "")).lower()
+        for item in sessions.values()
+        if int(item.get("expires", 0)) > now
+    }
