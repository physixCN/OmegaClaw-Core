+  const raw = normal.multiplyScalar(radius)
+    .add(tangent.multiplyScalar(Math.cos(angle) * scatter))
+    .add(bitangent.multiplyScalar(Math.sin(angle) * scatter))
+  return raw.normalize().multiplyScalar(radius)
