+  for (let i = 0; i < count; i += 1) {
+    const a = points[i]
+    const b = points[(i + 3 + (i % 5)) % count]
+    const mid = a.clone().lerp(b, .5).normalize().multiplyScalar(center.length() + radius * (.3 + hashUnit(`${seed}:m:${i}`) * .9))
