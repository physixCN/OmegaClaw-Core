+  const bitangent = new THREE.Vector3().crossVectors(normal, tangent).normalize()
+  return { normal, tangent, bitangent }
+}
+
+function nodePosition(id, ordinal, totalInCluster, clusterName, radius = SHELL_RADIUS) {
