+  const count = 24
+  for (let i = 0; i < count; i += 1) {
+    const a = ((i / count) - .5) * radius * (2.1 + hashUnit(`${seed}:sx`) * .9)
+    const b = (hashUnit(`${seed}:${i}:b`) - .5) * radius * 1.7
