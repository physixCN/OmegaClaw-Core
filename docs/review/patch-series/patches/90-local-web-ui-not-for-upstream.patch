+    cycles = cycles[-limit:]
+    for idx, cycle in enumerate(cycles, start=1):
+        cycle["index"] = idx
+    return {"cycles": cycles, "source": "history.metta", "phase_order": ["receive", "provider", "syntax", "metta", "skills", "memory", "outbound", "sleep"]}
