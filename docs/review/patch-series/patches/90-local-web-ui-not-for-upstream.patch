+  }
+
+  setLayerAlpha(alpha = 1) {
+    this.layerAlpha = THREE.MathUtils.clamp(alpha, 0, 1)
+  }
+
+  update(time, state) {
+    const activity = state.activity ?? .25
+    const quality = state.quality ?? 1
