+  }
+
+  focusNode(id = 'provider', event = null) {
+    this.graph.focusNode(id)
+  }
+
+  pointerDirection(event) {
+    const ndc = new THREE.Vector3(
+      (event.clientX / Math.max(1, window.innerWidth)) * 2 - 1,
+      -(event.clientY / Math.max(1, window.innerHeight)) * 2 + 1,
