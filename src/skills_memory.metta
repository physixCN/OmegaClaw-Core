(= (agenda-active)
   (repr (collapse (match &agenda (Goal $name active $priority $next)
                          (Goal $name $priority $next)))))

(= (agenda-waiting)
   (repr (collapse (match &agenda (Goal $name waiting $priority $next)
                          (Goal $name $priority $next)))))

(= (agenda-blocked)
   (repr (collapse (match &agenda (Goal $name blocked $priority $next)
                          (Goal $name $priority $next)))))

(= (agenda-scheduled)
   (repr (collapse (match &agenda (Goal $name scheduled $priority $next)
                          (Goal $name $priority $next)))))

(= (agenda-all)
   (repr (collapse (match &agenda (Goal $name $status $priority $next)
                          (Goal $name $status $priority $next)))))

(= (agenda-by-name $name)
   (repr (collapse (match &agenda (Goal $name $status $priority $next)
                          (Goal $status $priority $next)))))

(= (agenda-retire $name $reason)
   (progn (collapse (match &agenda (Goal $name $status $priority $next)
                           (remove-atom &agenda (Goal $name $status $priority $next))))
          (add-atom &agenda (Goal $name dormant medium $reason))
          (py-str (AGENDA-GOAL-RETIRED name: $name reason: $reason))))

(= (agenda-complete $name $reason)
   (progn (collapse (match &agenda (Goal $name $status $priority $next)
                           (remove-atom &agenda (Goal $name $status $priority $next))))
          (add-atom &agenda (Goal $name dormant low $reason))
          (trace-atom "write" "agenda" (Goal $name dormant low $reason) "agenda-complete")
          (py-str (AGENDA-GOAL-COMPLETED name: $name reason: $reason))))

(= (beliefs-about $domain $relation)
   (repr (collapse (match &beliefs (Belief $domain $relation $value $truth $source)
                          (Belief $value $truth $source)))))

(= (beliefs-for $domain)
   (repr (collapse (match &beliefs (Belief $domain $relation $value $truth $source)
                          (Belief $relation $value $truth $source)))))

(= (belief-derived $spec)
   (belief-claim $spec))

(= (belief-truth $domain $relation $value)
   (match &beliefs (Belief $domain $relation $value $truth $source) $truth))

(= (belief-revision-candidate $domain $relation $value $frequency $confidence)
   (Truth_Revision (belief-truth $domain $relation $value) (stv $frequency $confidence)))

(= (world-room $room)
   (repr (collapse (match &world (InRoom $device $room $confidence $source)
                          (InRoom $device $confidence $source)))))

(= (world-person $person)
   (repr (collapse (match &world (Relation $person $relation $other $confidence $source)
                          (Relation $relation $other $confidence $source)))))

(= (events-all)
   (repr (collapse (match &events (Event $source $kind $summary $confidence)
                          (Event $source $kind $summary $confidence)))))

(= (events-recent)
   (repr (takeK 12 (collapse (match &events (Event $source $kind $summary $confidence)
                                    (Event $source $kind $summary $confidence))))))

(= (export! $space $file)
   (progn (write-file $file "")
          (collapse (let $x (get-atoms $space)
                         (append-file $file (repr $x))))))

(= (bound-space! $space $limit)
   (progn (change-state! &exportchars 0)
          (collapse (let* (($x (get-atoms $space))
                           ($y (repr $x))
                           ($l (string_length $y))
                           ($_ (change-state! &exportchars (+ (get-state &exportchars) $l))))
                          (if (> (get-state &exportchars) $limit)
                              (remove-atom $space $x) _)))))
